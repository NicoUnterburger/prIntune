# printDeploy Backend – Konfiguration
# Diese Datei nach .env kopieren und anpassen. .env wird nicht eingecheckt.

# Port, auf dem die API lauscht.
PORT=3001

# Erlaubte CORS-Origins: "*" für alle, oder kommagetrennte Liste,
# z.B. https://printdeploy.example.com,https://intranet.example.com
CORS_ORIGIN=*

# Maximale Größe der hochgeladenen Treiber-ZIP in MB.
MAX_UPLOAD_MB=200

# Rate-Limit pro IP: max. Anzahl Requests je Zeitfenster.
RATE_LIMIT_WINDOW_MIN=15
RATE_LIMIT_MAX=300

# Log-Level: error | warn | info | debug
LOG_LEVEL=info
