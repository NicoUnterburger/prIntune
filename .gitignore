# Generated packages (history, server data, not source)
backend/data/generated/*
!backend/data/generated/.gitkeep

# Environment files
.env
.env.local

# Logs
npm-debug.log*

# Editor directories and files
.vscode/
.idea/
*.swp

# OS files
.DS_Store
